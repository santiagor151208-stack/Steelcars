{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "composer install --optimize-autoloader --no-dev --ignore-platform-req=php"
  },
  "deploy": {
    "startCommand": "php artisan migrate --force && php artisan serve --host=0.0.0.0 --port=8080",
    "healthcheckPath": "/health.txt",
    "restartPolicyType": "ON_FAILURE"
  }
}
